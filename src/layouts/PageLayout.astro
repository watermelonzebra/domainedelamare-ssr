---
/**
 * PageLayout
 * Composes BaseLayout with the persistent Header and Footer.
 * All standard pages should use this layout.
 *
 * Usage:
 *   <PageLayout title="About" description="Learn about us.">
 *     <p>Content goes here.</p>
 *   </PageLayout>
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/common/Header.astro';
import Footer from '@/components/common/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const props = Astro.props;
---

<BaseLayout {...props}>
  <Header slot="header" />

  <!-- Default slot passes through to BaseLayout's <main> -->
  <slot />

  <Footer slot="footer" />
</BaseLayout>
